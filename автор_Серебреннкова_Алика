import tkinter as tk
from tkinter import messagebox, ttk
import random
import string
import json
import os


HISTORY_FILE = "password_history.json"
MIN_LENGTH, MAX_LENGTH = 6, 32


def load_history():
    if os.path.exists(HISTORY_FILE):
        with open(HISTORY_FILE, "r", encoding="utf-8") as f:
            return json.load(f)
    return []

def save_history(history):
    with open(HISTORY_FILE, "w", encoding="utf-8") as f:
        json.dump(history, f, ensure_ascii=False, indent=2)

def generate_password():
    try:
        length = int(length_var.get())
        if not (MIN_LENGTH <= length <= MAX_LENGTH):
            raise ValueError
    except ValueError:
        messagebox.showerror("Ошибка", f"Длина должна быть от {MIN_LENGTH} до {MAX_LENGTH}!")
        return

    use_letters = letters_var.get()
    use_digits = digits_var.get()
    use_symbols = symbols_var.get()

    if not (use_letters or use_digits or use_symbols):
        messagebox.showwarning("Внимание", "Выберите хотя бы один тип символов!")
        return

    chars = ""
    if use_letters: chars += string.ascii_letters
    if use_digits:   chars += string.digits
    if use_symbols: chars += string.punctuation

    password = "".join(random.choices(chars, k=length))
    result_label.config(text=password)

   
    history.append({
        "password": password,
        "length": length,
        "letters": use_letters,
        "digits": use_digits,
        "symbols": use_symbols,
    })
    save_history(history)
    update_history_table()

def update_history_table():
    for i in history_treeview.get_children():
        history_treeview.delete(i)
    for i, entry in enumerate(history):
        history_treeview.insert("", "end", values=(
            entry["password"],
            entry["length"],
            "✓" if entry["letters"] else "",
            "✓" if entry["digits"] else "",
            "✓" if entry["symbols"] else ""
        ))

def copy_to_clipboard():
    password = result_label.cget("text")
    if password:
        root.clipboard_clear()
        root.clipboard_append(password)
        messagebox.showinfo("Готово", "Пароль скопирован в буфер обмена!")


history = load_history()


root = tk.Tk()
root.title("Random Password Generator")
root.geometry("600x450")
root.resizable(False, False)


tk.Label(root, text="Длина пароля:").pack(pady=5)
length_var = tk.IntVar(value=12)
length_slider = tk.Scale(root, from_=MIN_LENGTH, to=MAX_LENGTH, orient=tk.HORIZONTAL,
                         variable=length_var, length=300)
length_slider.pack(pady=5)

tk.Label(root, text="Состав пароля:").pack(pady=5)
letters_var = tk.BooleanVar(value=True)
digits_var = tk.BooleanVar(value=True)
symbols_var = tk.BooleanVar(value=True)
tk.Checkbutton(root, text="Буквы", variable=letters_var).pack(anchor='w')
tk.Checkbutton(root, text="Цифры", variable=digits_var).pack(anchor='w')
tk.Checkbutton(root, text="Символы", variable=symbols_var).pack(anchor='w')

tk.Button(root, text="Сгенерировать", command=generate_password).pack(pady=10)

result_label = tk.Label(root, text="", font=('Courier', 14), width=30)
result_label.pack(pady=10)
tk.Button(root, text="Копировать", command=copy_to_clipboard).pack(pady=5)


tk.Label(root, text="История:").pack(pady=5)
history_treeview = ttk.Treeview(root, columns=("Пароль", "Длина", "Буквы", "Цифры", "Символы"),
                                show="headings", height=10)
history_treeview.heading("Пароль", text="Пароль")
history_treeview.heading("Длина", text="Длина")
history_treeview.heading("Буквы", text="Буквы")
history_treeview.heading("Цифры", text="Цифры")
history_treeview.heading("Символы", text="Символы")
history_treeview.column("Пароль", width=200)
for col in ("Длина", "Буквы", "Цифры", "Символы"):
    history_treeview.column(col, width=80, anchor="center")
history_treeview.pack(fill="x", padx=20, pady=5)
update_history_table()

root.mainloop()
